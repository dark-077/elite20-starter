{
  "name": "个人联结追踪",
  "description": "追踪 C2S 产物③：AI+X 范式与自身联结",
  "properties": {
    "联结主题": {
      "type": "title",
      "description": "联结的核心主题"
    },
    "联结类型": {
      "type": "select",
      "options": ["专业联结", "生活联结", "情感联结", "职业联结"]
    },
    "具体事实": {
      "type": "text",
      "description": "具体的真实生活事实（不是泛泛而谈）"
    },
    "AI关联": {
      "type": "text",
      "description": "如何与 AI 工具/学习产生关联"
    },
    "独特性": {
      "type": "select",
      "options": ["模糊", "一般", "清晰", "独特"]
    },
    "状态": {
      "type": "select",
      "options": ["未开始", "构思中", "初稿", "完善中", "已完成"]
    },
    "完成度": {
      "type": "number",
      "format": "percent"
    },
    "最后修改": {
      "type": "date"
    }
  },
  "检查清单": [
    "是否提及了具体的专业背景？",
    "是否有真实发生的事件（非假设）？",
    "是否避免了泛泛而谈（如'我很感兴趣'）？",
    "是否能让读者感受到'这是一个真实的人'？",
    "联结是否自然而非强行绑定？"
  ]
}
