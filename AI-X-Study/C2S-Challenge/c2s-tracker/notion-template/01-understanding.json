{
  "name": "论文理解追踪",
  "description": "追踪 C2S 产物①：论文理解（摘要/翻译/评注/批评/建议）",
  "properties": {
    "名称": {
      "type": "title",
      "description": "内容名称或主题"
    },
    "类型": {
      "type": "select",
      "options": ["摘要", "翻译", "评注", "批评", "建议"]
    },
    "状态": {
      "type": "select",
      "options": ["未开始", "进行中", "待审核", "已完成"]
    },
    "完成度": {
      "type": "number",
      "format": "percent"
    },
    "质量等级": {
      "type": "select",
      "options": ["待改进", "合格", "良好", "优秀"]
    },
    "论文页码": {
      "type": "text",
      "description": "原文引用来源"
    },
    "个人解读": {
      "type": "text",
      "description": "你的分析/批评/建议"
    },
    "最后修改": {
      "type": "date"
    }
  },
  "检查清单": [
    "是否有原文引用？（页码标注）",
    "是否有个人解读（非纯复述）？",
    "是否区分了'论文讲的'和'我讲的'？",
    "是否有具体例子或证据支撑？",
    "评注是否提出了建设性意见？"
  ]
}
